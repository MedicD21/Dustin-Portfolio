---
import type { CollectionEntry } from 'astro:content';
import { url } from '../lib/url';

interface Props {
  note: CollectionEntry<'notes'>;
}

const { note } = Astro.props;
const dateLabel = note.data.date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<a href={url(`/notes/${note.id}`)} class="note quiet">
  <span class="title">{note.data.title}</span>
  <span class="dots" aria-hidden="true"></span>
  <time class="mono muted" datetime={note.data.date.toISOString()}>{dateLabel}</time>
</a>

<style>
  .note {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    padding-block: 0.55rem;
  }

  .title {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .note:hover .title {
    color: var(--accent);
  }

  .dots {
    flex: 1;
    border-bottom: 1px dotted var(--line-strong);
    transform: translateY(-0.25em);
  }

  time {
    font-size: 0.75rem;
    flex-shrink: 0;
  }
</style>
