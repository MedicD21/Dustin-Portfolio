---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectRow from '../components/ProjectRow.astro';
import NoteRow from '../components/NoteRow.astro';
import { SITE } from '../site.config';
import { url } from '../lib/url';

const allProjects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featured = allProjects.filter((p) => p.data.featured);
const selected = (featured.length > 0 ? featured : allProjects).slice(0, 3);

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base>
  <section class="hero">
    <h1>
      Hi, I'm {SITE.name} <span class="wave" aria-hidden="true">—</span>
      <span class="serif">{SITE.tagline.replace(/\.$/, '')}.</span>
    </h1>
    <p class="intro muted">{SITE.intro}</p>
    <p class="hero-links">
      <a href={url('/projects')} class="quiet mono">see my work →</a>
      <a href={`mailto:${SITE.email}`} class="quiet mono">say hello →</a>
    </p>
  </section>

  <section class="section" aria-labelledby="now-label">
    <h2 class="section-label" id="now-label">Now</h2>
    <ul class="now">
      {SITE.now.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="section" aria-labelledby="projects-label">
    <h2 class="section-label" id="projects-label">Selected projects</h2>
    <div class="project-list">
      {selected.map((project) => <ProjectRow project={project} />)}
    </div>
    <a href={url('/projects')} class="more quiet mono">all projects →</a>
  </section>

  {notes.length > 0 && (
    <section class="section" aria-labelledby="notes-label">
      <h2 class="section-label" id="notes-label">Recent notes</h2>
      <div>
        {notes.map((note) => <NoteRow note={note} />)}
      </div>
      <a href={url('/notes')} class="more quiet mono">all notes →</a>
    </section>
  )}

  <section class="section" aria-labelledby="connect-label">
    <h2 class="section-label" id="connect-label">Connect</h2>
    <p class="connect">
      I'm early in this journey and glad to meet people who are further
      along — or just starting too. The fastest way to reach me is
      <a href={`mailto:${SITE.email}`}>email</a>, and my work-in-progress
      lives on <a href={`https://github.com/${SITE.github}`} target="_blank" rel="noopener noreferrer">GitHub</a>.
    </p>
  </section>
</Base>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-top: 1.5rem;
  }

  h1 {
    font-size: clamp(1.7rem, 5.5vw, 2.35rem);
    font-weight: 650;
    line-height: 1.3;
  }

  h1 .serif {
    color: var(--text-muted);
    font-size: 0.96em;
  }

  .wave {
    color: var(--accent);
  }

  .intro {
    max-width: 36rem;
    font-size: 1.02rem;
  }

  .hero-links {
    display: flex;
    gap: 1.75rem;
    margin-top: 0.25rem;
  }

  .hero-links a {
    font-size: 0.85rem;
    color: var(--accent);
  }

  .now {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .now li {
    position: relative;
    padding-left: 1.35rem;
    font-size: 0.95rem;
  }

  .now li::before {
    content: '▹';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .more {
    align-self: flex-start;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .more:hover {
    color: var(--accent);
  }

  .connect {
    font-size: 0.98rem;
    max-width: 36rem;
  }
</style>
