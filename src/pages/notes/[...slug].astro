---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { url } from '../../lib/url';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
const dateLabel = note.data.date.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<Base title={note.data.title} description={note.data.description}>
  <article class="section">
    <header class="head">
      <a href={url('/notes')} class="back quiet mono">← notes</a>
      <h1>{note.data.title}</h1>
      <time class="mono muted" datetime={note.data.date.toISOString()}>{dateLabel}</time>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .head {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--line);
  }

  .back {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .back:hover {
    color: var(--accent);
  }

  h1 {
    font-size: 1.65rem;
  }

  time {
    font-size: 0.78rem;
  }
</style>
